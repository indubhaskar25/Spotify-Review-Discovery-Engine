# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Only GROQ_API_KEY is used. OpenAI is NOT used by this project.
# Leave unset to run in offline/mock mode (all pages still work; Ask AI returns
# pre-computed responses).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Reddit ingestion (optional) ───────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=spotify-review-engine/1.0

# ── Storage paths ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
DATA_DIR=./data

# ── Retrieval ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_RETRIEVAL=20
